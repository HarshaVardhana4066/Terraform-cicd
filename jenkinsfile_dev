pipeline{
    agent any

    tools {
        jdk 'java-17'
        maven 'maven3.9'
    }

    stages{
        stage('git checkout'){
            steps {
                git branch: 'main', url: 'https://github.com/HarshaVardhana4066/Boardgame.git'
            }
        }
        stage('check'){
            steps {
                echo "Testing to check i had created dev branch"
            }
        }

        stage('compile'){
            steps {
                sh 'mvn compile'
            }
        }

        stage('test'){
            steps {
                sh 'mvn test'    
            }
        }

        stage('build'){
            steps {
                sh 'mvn package'    
            }
        }
    }
}